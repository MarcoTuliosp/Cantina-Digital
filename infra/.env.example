# ═══════════════════════════════════════════════════════
# Cantina Digital — Variáveis de Ambiente (Cloud)
# ═══════════════════════════════════════════════════════
# Copie este arquivo e preencha com seus valores reais.
# NÃO versione o .env real no git!

# ─── PostgreSQL (Neon.tech — Free Tier) ───
DATABASE_URL=jdbc:postgresql://SEU-HOST.neon.tech:5432/cantina_db?sslmode=require
DATABASE_USER=cantina_user
DATABASE_PASSWORD=GERADO_PELO_NEON

# ─── Backend (Render — Free Tier) ───
# URL gerada pelo Render após deploy
API_URL=https://SEU-BACKEND.onrender.com
PORT=8080

# ─── Frontend (Vercel — Hobby) ───
# URL gerada pelo Vercel após deploy
FRONTEND_URL=https://SEU-FRONTEND.vercel.app

# ─── CORS ───
CORS_ORIGINS=https://SEU-FRONTEND.vercel.app,http://localhost:5173

# ─── n8n (Render — Free Tier) — Futuramente ───
# N8N_WEBHOOK_PEDIDO=https://SEU-N8N.onrender.com/webhook/pedido-recebido
# N8N_WEBHOOK_RELATORIO=https://SEU-N8N.onrender.com/webhook/gerar-relatorio

# ─── Redis (Upstash — Free Tier) — Futuramente ───
# REDIS_URL=rediss://SEU-ENDPOINT.upstash.io:6379
# REDIS_PASSWORD=GERADO_PELO_UPSTASH

# ─── Timezone ───
TZ=America/Sao_Paulo
